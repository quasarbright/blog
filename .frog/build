\">proc</span><span class=\"RktPn\">)</span></td></tr></tbody></table></td></tr>\n   <tr>\n    <td><span class=\"RktCmt\">;</span><span class=\"RktCmt\">&nbsp;</span><span class=\"RktCmt\">ProcessQueue {(listof Process)} -&gt; (values Process ProcessQueue)</span></td></tr>\n   <tr>\n    <td><span class=\"RktCmt\">;</span><span class=\"RktCmt\">&nbsp;</span><span class=\"RktCmt\">pops the next unblocked process from the queue immutably.</span></td></tr>\n   <tr>\n    <td><span class=\"RktCmt\">;</span><span class=\"RktCmt\">&nbsp;</span><span class=\"RktCmt\">skipped-rev is an accumulator storing the blocked processes</span></td></tr>\n   <tr>\n    <td><span class=\"RktCmt\">;</span><span class=\"RktCmt\">&nbsp;</span><span class=\"RktCmt\">at the head of the queue in reverse order.</span></td></tr>\n   <tr>\n    <td>\n     <table cellpadding=\"0\" cellspacing=\"0\" class=\"RktBlk\">\n      <tbody>\n       <tr>\n        <td><span class=\"stt\">&gt; </span><span class=\"RktPn\">(</span><span class=\"RktSym\"><a class=\"RktStxLink Sq\" data-pltdoc=\"x\" href=\"https://docs.racket-lang.org/reference/define.html#%28form._%28%28lib._racket%2Fprivate%2Fbase..rkt%29._define%29%29\">define</a></span><span class=\"hspace\">&nbsp;</span><span class=\"RktPn\">(</span><span class=\"RktSym\">pop-unblocked-process</span><span class=\"hspace\">&nbsp;</span><span class=\"RktSym\">pq</span><span class=\"hspace\">&nbsp;</span><span class=\"RktPn\">[</span><span class=\"RktSym\">skipped-rev</span><span class=\"hspace\">&nbsp;</span><span class=\"RktVal\">'</span><span class=\"RktVal\">(</span><span class=\"RktVal\">)</span><span class=\"RktPn\">]</span><span class=\"RktPn\">)</span></td></tr>\n       <tr>\n        <td><span class=\"hspace\">&nbsp;&nbsp;</span><span class=\"hspace\">&nbsp;&nbsp;</span><span class=\"RktPn\">(</span><span class=\"RktSym\"><a class=\"RktStxLink Sq\" data-pltdoc=\"x\" href=\"https://docs.racket-lang.org/reference/if.html#%28form._%28%28lib._racket%2Fprivate