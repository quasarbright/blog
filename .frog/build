rivativeZeros</span><span class=\"p\">[</span><span class=\"nx\">i</span><span class=\"p\">]</span>\n        <span class=\"kd\">const</span> <span class=\"nx\">right</span> <span class=\"o\">=</span> <span class=\"nx\">derivativeZeros</span><span class=\"p\">[</span><span class=\"nx\">i</span><span class=\"o\">+</span><span class=\"mf\">1</span><span class=\"p\">]</span>\n        <span class=\"kd\">const</span> <span class=\"nx\">isSignChange</span> <span class=\"o\">=</span> <span class=\"nx\">evalPolynomial</span><span class=\"p\">(</span><span class=\"nx\">p</span><span class=\"p\">,</span> <span class=\"nx\">left</span><span class=\"p\">)</span> <span class=\"o\">*</span> <span class=\"nx\">evalPolynomial</span><span class=\"p\">(</span><span class=\"nx\">p</span><span class=\"p\">,</span> <span class=\"nx\">right</span><span class=\"p\">)</span> <span class=\"o\">&lt;</span> <span class=\"mf\">0</span>\n        <span class=\"k\">if</span> <span class=\"p\">(</span><span class=\"nx\">isZero</span><span class=\"p\">(</span><span class=\"nx\">p</span><span class=\"p\">,</span> <span class=\"nx\">left</span><span class=\"p\">))</span> <span class=\"p\">{</span>\n            <span class=\"nx\">zeros</span><span class=\"p\">.</span><span class=\"nx\">push</span><span class=\"p\">(</span><span class=\"nx\">left</span><span class=\"p\">)</span>\n        <span class=\"p\">}</span>\n        <span class=\"k\">if</span> <span class=\"p\">(</span><span class=\"nx\">isZero</span><span class=\"p\">(</span><span class=\"nx\">p</span><span class=\"p\">,</span> <span class=\"nx\">right</span><span class=\"p\">))</span> <span class=\"p\">{</span>\n            <span class=\"nx\">zeros</span><span class=\"p\">.</span><span class=\"nx\">push</span><span class=\"p\">(</span><span class=\"nx\">right</span><span class=\"p\">)</span>\n            <span class=\"c1\">// skip the next pair of zeros to avoid duplicates</span>\n            <span class=\"nx\">i</span><span class=\"o\">++</spa